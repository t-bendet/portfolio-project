{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/inject-project-state.ts"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/protect-reference.ts"
          },
          {
            "type": "command",
            "command": "node scripts/hooks/mission-gate.ts"
          },
          {
            "type": "command",
            "command": "node scripts/hooks/protect-workshop.ts"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hooks/decision-guard.ts"
          }
        ]
      }
    ]
  }
}
