---
// Home (/) — specs/pages/home.md. Sections in the brief's order; sections 4
// and 5 are composed away entirely when their collection is empty (§3.2), so
// no heading ever stands over a void.
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import HeroMark from '../components/HeroMark.astro';
// The card is one device wherever it appears (specs/pages/projects-index.md
// §2.2); the stylesheet and the destination rule are shared with /projects/.
import { destination } from '../lib/projects';
import '../styles/projects.css';

const writing = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const isoDate = (d: Date) => d.toISOString().slice(0, 10);
---

{/* TODO: Tal's copy — the title's short descriptor and the meta description */}
<Base title="T://bendet" description="TODO: Tal's copy" section="home">
  <HeroMark />

  {/* One opacity step at completion; visible without JavaScript (home.md §3.1) */}
  <div class="hero-reveal">
    <p class="tagline">{/* TODO: Tal's copy */}</p>

    {
      writing.length > 0 && (
        <section class="block">
          <h2 class="block-title">recent writing</h2>
          <ul class="rows">
            {writing.map((entry) => (
              <li class="row">
                <a class="row-title" href={`/writing/${entry.id}/`}>
                  {entry.data.title}
                </a>
                <p class="row-desc">{entry.data.description}</p>
                <time class="row-meta" datetime={isoDate(entry.data.pubDate)}>
                  {isoDate(entry.data.pubDate)}
                </time>
              </li>
            ))}
          </ul>
          <a class="block-link" href="/writing/">
            writing
          </a>
        </section>
      )
    }

    {
      projects.length > 0 && (
        <section class="block">
          <h2 class="block-title">selected projects</h2>
          <ul class="cards">
            {projects.map((project) => {
              const { href, host } = destination(project);
              // aria-describedby, so the host reaches a reader navigating by
              // links — §2.2's test is what a visitor can tell before the
              // click, and a span outside the anchor tells only sighted ones.
              const hostId = `card-host-${project.id}`;
              return (
                <li class="card">
                  <a
                    class="card-title"
                    href={href}
                    rel={host === null ? undefined : 'noopener'}
                    aria-describedby={host === null ? undefined : hostId}
                  >
                    {project.data.title}
                  </a>
                  <p class="card-desc">{project.data.description}</p>
                  {host !== null && (
                    <span class="card-host" id={hostId}>
                      {host}
                    </span>
                  )}
                  {project.data.stack.length > 0 && (
                    <ul class="stack-chips">
                      {project.data.stack.map((item, index) => (
                        <li class={`stack-chip accent-${(index % 6) + 1}`}>{item}</li>
                      ))}
                    </ul>
                  )}
                </li>
              );
            })}
          </ul>
          <a class="block-link" href="/projects/">
            projects
          </a>
        </section>
      )
    }

    <p class="person-line">
      {/* TODO: Tal's copy */}
      <a href="/about/">about</a>
    </p>
  </div>
</Base>

<style>
  .tagline {
    margin-block-start: 24px;
    font-size: var(--size-lede);
    color: var(--text);
    max-inline-size: 44ch;
  }

  .block {
    margin-block-start: 72px;
  }

  /* The overview archetype's section header device: mono caps at --size-meta
     (specs/design/typography.md §4). */
  .block-title {
    font-family: var(--font-mono);
    font-size: var(--size-meta);
    font-weight: 500;
    letter-spacing: var(--track-label);
    text-transform: uppercase;
    color: var(--muted);
    padding-block-end: 12px;
    border-block-end: 1px solid var(--border);
  }

  /* The card grid, the stack chip and the destination host live in
     src/styles/projects.css — one device across / and /projects/. What is
     left here is the home page's own composition. */
  .rows {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .row {
    padding-block: 20px;
    border-block-end: 1px solid var(--border);
  }

  .row-title {
    display: inline-block;
    font-size: var(--size-lede);
    font-weight: 700;
    color: var(--text-strong);
    text-decoration: none;
  }

  .row-title:hover {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .row-desc {
    margin-block-start: 6px;
    font-size: var(--size-meta);
    color: var(--muted);
  }

  .row-meta {
    display: block;
    margin-block-start: 8px;
    font-family: var(--font-mono);
    font-size: var(--size-eyebrow);
    color: var(--muted);
  }

  .block-link {
    display: inline-block;
    margin-block-start: 20px;
    font-family: var(--font-mono);
    font-size: var(--size-meta);
    color: var(--muted);
    text-decoration: none;
    border-inline-start: 2px solid var(--border-strong);
    padding-inline-start: 12px;
    transition: color var(--motion-hover) ease;
  }

  .block-link:hover {
    color: var(--text);
  }

  .person-line {
    margin-block-start: 72px;
    font-size: var(--size-body);
    color: var(--muted);
  }

  @media (prefers-reduced-motion: reduce) {
    .block-link {
      transition: none;
    }
  }
</style>
