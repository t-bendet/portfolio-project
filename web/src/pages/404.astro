---
// Not found (/404) — specs/pages/not-found.md. Minimal archetype: a
// statement and two links, inside the same chrome as every other page (§5).
// No wink, no joke, no list of sections.
import Base from '../layouts/Base.astro';
---

{/* TODO: Tal's copy — the statement line and the meta description */}
<Base title="404 · T://bendet" description="TODO: Tal's copy" section="404">
  <p class="statement">{/* TODO: Tal's copy */}</p>

  <ul class="routes">
    <li><a href="/writing/">writing</a></li>
    <li><a href="/">home</a></li>
  </ul>
</Base>

<style>
  .statement {
    font-size: var(--size-lede);
    color: var(--text);
    max-inline-size: 44ch;
  }

  .routes {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 24px;
    margin-block-start: 32px;
    list-style: none;
    padding: 0;
  }

  .routes a {
    font-family: var(--font-mono);
    font-size: var(--size-meta);
    color: var(--text);
    text-decoration: none;
    border-inline-start: 2px solid var(--border-strong);
    padding-inline-start: 12px;
    transition: color var(--motion-hover) ease;
  }

  .routes a:hover {
    color: var(--text-strong);
  }

  @media (prefers-reduced-motion: reduce) {
    .routes a {
      transition: none;
    }
  }
</style>
